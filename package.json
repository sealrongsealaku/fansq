{
  "name": "fansq",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm run dev -w @fansq/admin-web",
    "dev:public": "npm run dev -w @fansq/public-web",
    "dev:api": "npm run dev -w @fansq/api-server",
    "dev:bot": "npm run dev -w @fansq/qq-bot",
    "admin:hash": "node ./deploy/scripts/generate-password-hash.mjs",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
