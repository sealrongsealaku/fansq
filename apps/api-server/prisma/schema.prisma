generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  username     String    @unique @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         String    @default("admin") @db.VarChar(50)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(0)
  auditLogs    AuditLog[]

  @@map("admin_user")
}

model Reflection {
  id               BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  studentName      String           @map("student_name") @db.VarChar(100)
  submitContent    String           @map("submit_content") @db.Text
  submitTime       DateTime         @map("submit_time") @db.DateTime(0)
  submitChannel    String           @default("qq_group_bot") @map("submit_channel") @db.VarChar(50)
  sourceGroupId    String?          @map("source_group_id") @db.VarChar(100)
  sourceGroupName  String?          @map("source_group_name") @db.VarChar(200)
  rawMessageId     String?          @map("raw_message_id") @db.VarChar(100)
  reflectionTypeId BigInt?          @map("reflection_type_id") @db.UnsignedBigInt
  teachingProjectId BigInt?         @map("teaching_project_id") @db.UnsignedBigInt
  auditStatus      String           @default("pending") @map("audit_status") @db.VarChar(20)
  displayStatus    String           @default("hidden") @map("display_status") @db.VarChar(20)
  isFeatured       Boolean          @default(false) @map("is_featured")
  isTop            Boolean          @default(false) @map("is_top")
  isAnonymous      Boolean          @default(false) @map("is_anonymous")
  displayName      String?          @map("display_name") @db.VarChar(100)
  likeCount        Int              @default(0) @map("like_count") @db.UnsignedInt
  remarks          String?          @db.Text
  createdAt        DateTime         @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.DateTime(0)
  reflectionType   ReflectionType?  @relation(fields: [reflectionTypeId], references: [id])
  teachingProject  TeachingProject? @relation(fields: [teachingProjectId], references: [id])
  likes            ReflectionLike[]
  auditLogs        AuditLog[]

  @@index([submitTime], map: "idx_reflection_submit_time")
  @@index([auditStatus], map: "idx_reflection_audit_status")
  @@index([displayStatus], map: "idx_reflection_display_status")
  @@index([sourceGroupId], map: "idx_reflection_group_id")
  @@index([reflectionTypeId], map: "idx_reflection_type_id")
  @@index([teachingProjectId], map: "idx_reflection_teaching_project_id")
  @@index([createdAt], map: "idx_reflection_created_at")
  @@index([isTop, submitTime], map: "idx_reflection_public_sort")
  @@index([auditStatus, displayStatus, isFeatured], map: "idx_reflection_public_filter")
  @@index([likeCount], map: "idx_reflection_like_count")
  @@index([rawMessageId], map: "idx_reflection_raw_message_id")
  @@map("reflection")
}

model ReflectionType {
  id              BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  name            String       @db.VarChar(100)
  code            String       @unique @db.VarChar(50)
  requiresProject Boolean      @default(false) @map("requires_project")
  isActive        Boolean      @default(true) @map("is_active")
  sortOrder       Int          @default(0) @map("sort_order")
  createdAt       DateTime     @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.DateTime(0)
  reflections     Reflection[]

  @@index([isActive, sortOrder], map: "idx_reflection_type_active_sort")
  @@map("reflection_type")
}

model TeachingProject {
  id          BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  name        String       @db.VarChar(100)
  code        String?      @unique @db.VarChar(50)
  isActive    Boolean      @default(true) @map("is_active")
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.DateTime(0)
  reflections Reflection[]

  @@index([isActive, sortOrder], map: "idx_teaching_project_active_sort")
  @@map("teaching_project")
}

model ReflectionLike {
  id           BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  reflectionId BigInt     @map("reflection_id") @db.UnsignedBigInt
  visitorId    String     @map("visitor_id") @db.VarChar(100)
  createdAt    DateTime   @default(now()) @map("created_at") @db.DateTime(0)
  reflection   Reflection @relation(fields: [reflectionId], references: [id], onDelete: Cascade)

  @@unique([reflectionId, visitorId], map: "uk_reflection_like_unique")
  @@index([visitorId], map: "idx_reflection_like_visitor_id")
  @@index([createdAt], map: "idx_reflection_like_created_at")
  @@map("reflection_like")
}

model AuditLog {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  reflectionId BigInt    @map("reflection_id") @db.UnsignedBigInt
  adminUserId  BigInt    @map("admin_user_id") @db.UnsignedBigInt
  action       String    @db.VarChar(50)
  actionDetail String?   @map("action_detail") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  reflection   Reflection @relation(fields: [reflectionId], references: [id])
  adminUser    AdminUser  @relation(fields: [adminUserId], references: [id])

  @@index([reflectionId], map: "idx_audit_log_reflection_id")
  @@index([adminUserId], map: "idx_audit_log_admin_user_id")
  @@index([createdAt], map: "idx_audit_log_created_at")
  @@map("audit_log")
}
